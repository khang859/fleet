%% Star Command — System Diagrams
%% ================================

%% 1. SUPERVISION TREE (Let It Crash)
%% Shows the OTP-style supervision hierarchy

---
title: Supervision Tree
---
graph TD
    Fleet["Fleet<br/>(Electron Main Process)"]
    Sentinel["Sentinel<br/>(Watchdog Sweep, every 10s)"]
    H1["Hull A"]
    H2["Hull B"]
    H3["Hull C"]
    C1["Crewmate A<br/>(claude)"]
    C2["Crewmate B<br/>(opencode)"]
    C3["Crewmate C<br/>(aider)"]
    DB[("Starbase DB<br/>SQLite WAL")]
    PTY["PTY Exit Events"]

    Fleet --> Sentinel
    Fleet --> H1
    Fleet --> H2
    Fleet --> H3
    H1 --> C1
    H2 --> C2
    H3 --> C3

    H1 -. "Lifesigns" .-> DB
    H2 -. "Lifesigns" .-> DB
    H3 -. "Lifesigns" .-> DB
    Sentinel -. "sweeps" .-> DB
    Fleet -. "listens" .-> PTY

    style Fleet fill:#1a1a2e,stroke:#0ff,color:#fff
    style Sentinel fill:#1a1a2e,stroke:#f0c040,color:#fff
    style H1 fill:#1a1a2e,stroke:#0ff,color:#fff
    style H2 fill:#1a1a2e,stroke:#0ff,color:#fff
    style H3 fill:#1a1a2e,stroke:#0ff,color:#fff
    style C1 fill:#2a2a4e,stroke:#888,color:#fff
    style C2 fill:#2a2a4e,stroke:#888,color:#fff
    style C3 fill:#2a2a4e,stroke:#888,color:#fff
    style DB fill:#0d1b2a,stroke:#0ff,color:#fff

---

%% 2. MISSION LIFECYCLE
%% Shows every state a Mission can be in and the transitions between them

---
title: Mission Lifecycle
---
stateDiagram-v2
    [*] --> queued: Admiral creates Mission

    queued --> active: Crewmate deployed
    active --> completed: Gate 2 pass + Gate 3 pass
    active --> failed_verification: Gate 2 fail
    active --> failed: Crewmate error/crash
    active --> timeout: Deadline exceeded
    active --> hailing: Crewmate blocked

    hailing --> active: Admiral resolves
    hailing --> timeout: Deadline exceeded while hailing

    failed_verification --> queued: Admiral re-queues with revised prompt
    failed --> queued: Admiral re-deploys
    timeout --> queued: Admiral re-scopes & re-queues

    completed --> [*]
    failed_verification --> [*]: Abandoned
    failed --> [*]: Abandoned
    timeout --> [*]: Abandoned

    state active {
        [*] --> working
        working --> committing
        committing --> working
        committing --> signaling_complete
    }

---

%% 3. DEPLOY → PR SEQUENCE
%% Full sequence from Admiral issuing deploy to PR creation

---
title: Deploy to PR Sequence
---
sequenceDiagram
    participant You
    participant Admiral
    participant Fleet as Fleet Main
    participant Hull
    participant Crew as Crewmate
    participant Git
    participant GH as GitHub

    You->>Admiral: "Add rate limiting to the API"
    Admiral->>Admiral: Decompose into Missions<br/>Write acceptance criteria
    Admiral->>Fleet: starbase.deploy({ sector: "api", mission: 42 })

    Fleet->>Hull: Spawn Hull process
    Hull->>Hull: Pre-flight checks<br/>(git repo? disk space? branch available?)
    Hull->>Git: git worktree add ~/.fleet/worktrees/.../crew-a3f8<br/>-b crew/crew-a3f8
    Hull->>Hull: npm install (120s timeout)
    Hull->>Crew: Spawn agent in worktree cwd<br/>with Mission prompt + MCP tools

    loop Every 10s
        Hull-->>Hull: Write Lifesign to DB
    end

    Crew->>Crew: Write code, commit
    Crew-->>Admiral: starbase.hail("need Redis or in-memory?")
    Admiral-->>You: "Crewmate asks: Redis or in-memory?"
    You-->>Admiral: "In-memory"
    Admiral-->>Crew: starbase.resolve(txId, "in-memory")
    Crew->>Crew: Continue working, commit

    Crew->>Hull: Exit 0 (or completeMission)

    Note over Hull: Gate 2 — Automated Verification
    Hull->>Hull: git diff --stat (changes exist? ✅)
    Hull->>Hull: npm run build && npm test (pass? ✅)
    Hull->>Hull: lint (warnings only, non-blocking)

    Hull->>Git: git push -u origin crew/crew-a3f8
    Hull->>GH: gh pr create --title "Add rate limiting"

    Note over Admiral: Gate 3 — Admiral Review
    Admiral->>GH: gh pr diff 15
    Admiral->>Admiral: Check acceptance criteria vs diff
    Admiral-->>You: "PR #15 ready. All criteria met."

    Hull->>Hull: Clean up worktree

---

%% 4. SYSTEM ARCHITECTURE
%% Shows how all components connect

---
title: System Architecture
---
graph LR
    subgraph Electron["Fleet (Electron)"]
        direction TB
        Main["Main Process"]
        IPC["IPC Bridge"]
        Renderer["React Renderer"]

        subgraph StarTab["Star Command Tab"]
            Viz["Visualizer<br/>(CSS Sprites + Canvas)"]
            Terminal["Admiral Terminal<br/>(xterm.js)"]
            Tabs["Sub-Tabs<br/>Bridge | Comms | Missions | Log | Config"]
        end
    end

    subgraph Hulls["Hull Processes"]
        H1["Hull + PTY<br/>(Crew A)"]
        H2["Hull + PTY<br/>(Crew B)"]
        H3["Hull + PTY<br/>(Crew C)"]
    end

    subgraph Storage["~/.fleet/"]
        DB[("starbase-a3f8c2.db<br/>SQLite WAL")]
        WT["worktrees/<br/>crew-a/ crew-b/ crew-c/"]
        Index["starbases/<br/>index.json"]
    end

    subgraph External["External"]
        Git["Git Remote<br/>(origin)"]
        GitHub["GitHub API<br/>(gh CLI)"]
    end

    Main --> IPC --> Renderer
    Main --> H1
    Main --> H2
    Main --> H3
    Main --> DB

    H1 --> DB
    H2 --> DB
    H3 --> DB

    H1 --> WT
    H2 --> WT
    H3 --> WT

    H1 --> Git
    H2 --> Git
    H1 --> GitHub

    Renderer --> Viz
    Renderer --> Terminal
    Renderer --> Tabs

    style Main fill:#1a1a2e,stroke:#0ff,color:#fff
    style DB fill:#0d1b2a,stroke:#0ff,color:#fff
    style Viz fill:#1a1a2e,stroke:#0f0,color:#fff
    style Terminal fill:#1a1a2e,stroke:#f0c040,color:#fff

---

%% 5. QUALITY GATES FLOWCHART
%% Shows the three gates and outcomes

---
title: Quality Gates
---
flowchart TD
    Start([Mission Created]) --> G1

    subgraph G1["Gate 1: Mission Brief"]
        G1Check{"Has summary +<br/>prompt +<br/>acceptance_criteria?"}
    end

    G1Check -->|No| G1Fail["Admiral revises brief"]
    G1Fail --> G1Check
    G1Check -->|Yes| Deploy["Deploy Crewmate"]

    Deploy --> Work["Crewmate executes Mission"]
    Work --> Exit{"Exit code?"}

    Exit -->|"!= 0 / crash / timeout"| PushPartial["Push partial branch<br/>Mark failed"]
    PushPartial --> End1([Mission Failed<br/>Re-queue or abandon])

    Exit -->|"0 (clean)"| G2

    subgraph G2["Gate 2: Hull Verification"]
        DiffCheck{"git diff<br/>has changes?"}
        DiffCheck -->|No| NoWork["Mark failed:<br/>no work produced"]
        DiffCheck -->|Yes| Verify{"verify_command<br/>passes?"}
        Verify -->|No| VerifyFail["Push branch<br/>Mark failed-verification<br/>No PR created"]
        Verify -->|Yes| Lint["lint_command<br/>(warnings only)"]
        Lint --> Push["Push branch + Create PR"]
    end

    NoWork --> End2([Mission Failed])
    VerifyFail --> End3([Hail Admiral with output])

    Push --> ReviewMode{"review_mode?"}

    ReviewMode -->|"verify-only"| Done([Mission Complete ✅])
    ReviewMode -->|"manual"| Manual([PR open for you to review])
    ReviewMode -->|"admiral-review"| G3

    subgraph G3["Gate 3: Admiral Review"]
        Review{"Check acceptance<br/>criteria vs diff"}
        Review -->|Pass| Approve["Approve PR"]
        Review -->|Request Changes| Fix["Deploy fix Mission<br/>on same branch"]
        Review -->|Reject| Reject["Close PR<br/>Re-queue with revised prompt"]
    end

    Approve --> Done2([Mission Complete ✅])
    Fix --> Work
    Reject --> G1Check

    style G1 fill:#0d1b2a,stroke:#0ff,color:#fff
    style G2 fill:#0d1b2a,stroke:#f0c040,color:#fff
    style G3 fill:#0d1b2a,stroke:#0f0,color:#fff

---

%% 6. CROSS-SECTOR COORDINATION
%% Shows Supply Routes and Cargo flow

---
title: Cross-Sector Coordination
---
graph TD
    subgraph API["Sector: API"]
        M1["Mission: Add rate limiting"]
        M2["Mission: Update OpenAPI spec"]
        C1["Cargo: rate-limit headers"]
        C2["Cargo: endpoint spec"]
    end

    subgraph Web["Sector: Web"]
        M3["Mission: Migrate auth flow"]
        M4["Mission: Update API client"]
    end

    subgraph Docs["Sector: Docs"]
        M5["Mission: Regenerate API reference"]
    end

    subgraph Admiral["Admiral"]
        Queue["Mission Queue"]
        Route["Supply Route Engine"]
    end

    M1 -->|produces| C1
    M2 -->|produces| C2

    C1 -->|"Supply Route:<br/>api → web"| Route
    C2 -->|"Supply Route:<br/>api → web"| Route
    C2 -->|"Supply Route:<br/>api → docs"| Route

    Route -->|"forwards Cargo"| M3
    Route -->|"forwards Cargo"| M5

    M1 -->|"depends_on"| M3
    M2 -->|"depends_on"| M5

    Queue --> M1
    Queue --> M2
    Queue --> M3
    Queue --> M4
    Queue --> M5

    style API fill:#1a1a2e,stroke:#0ff,color:#fff
    style Web fill:#1a1a2e,stroke:#0f0,color:#fff
    style Docs fill:#1a1a2e,stroke:#f0c040,color:#fff
    style Admiral fill:#0d1b2a,stroke:#fff,color:#fff

---

%% 7. HULL LIFECYCLE (Let It Crash)
%% Shows what the Hull does at each stage, including failure paths

---
title: Hull Lifecycle
---
stateDiagram-v2
    [*] --> preflight: Fleet spawns Hull

    preflight --> worktree_setup: Checks pass
    preflight --> failed: Pre-flight fail<br/>(no git, disk full)

    worktree_setup --> pkg_install: Worktree created
    worktree_setup --> direct_run: Not a git repo<br/>(skip worktree)
    worktree_setup --> failed: Worktree creation fail

    pkg_install --> agent_running: Install success
    pkg_install --> agent_running: Install fail → symlink fallback
    pkg_install --> failed: Install + fallback both fail

    direct_run --> agent_running

    state agent_running {
        [*] --> alive
        alive --> alive: Lifesign every 10s
        alive --> exit_clean: Exit code 0
        alive --> exit_error: Exit code != 0
        alive --> exit_timeout: Deadline exceeded
        alive --> exit_lost: SIGTERM / crash
    }

    exit_clean --> gate2_verify
    exit_error --> push_partial
    exit_timeout --> push_partial
    exit_lost --> push_partial

    gate2_verify --> push_and_pr: Verify passes
    gate2_verify --> push_no_pr: Verify fails

    push_and_pr --> cleanup
    push_no_pr --> cleanup
    push_partial --> cleanup

    failed --> hail_admiral
    hail_admiral --> [*]: Mission re-queued

    cleanup --> [*]: Worktree removed or pooled

---

%% 8. DATABASE ENTITY RELATIONSHIP
%% Shows the schema relationships

---
title: Starbase Database Schema
---
erDiagram
    SECTORS {
        text id PK "slug: api, web"
        text name "API Service"
        text root_path "/projects/api"
        text stack "typescript/node"
        text verify_command "npm run build && npm test"
        text review_mode "admiral-review"
        text merge_strategy "pr"
        text base_branch "main"
    }

    SUPPLY_ROUTES {
        int id PK
        text upstream_sector_id FK
        text downstream_sector_id FK
        text relationship "api_consumer"
    }

    MISSIONS {
        int id PK
        text sector_id FK
        text crew_id FK
        text summary
        text prompt
        text acceptance_criteria "JSON array"
        text status "queued|active|completed|failed"
        text verify_result "JSON"
        text review_verdict "pass|reject|request-changes"
        int depends_on_mission_id FK
    }

    CREW {
        text id PK "auth-crew-a3f8"
        text tab_id FK
        text sector_id FK
        int mission_id FK
        text status "active|hailing|error|lost|complete"
        int pid
        text worktree_path
        text worktree_branch
        datetime last_lifesign
        datetime deadline
    }

    COMMS {
        int id PK
        text from_crew FK
        text to_crew FK
        text thread_id
        text type "hailing|directive|cargo_manifest"
        text payload "JSON"
        boolean read
    }

    CARGO {
        int id PK
        text crew_id FK
        text sector_id FK
        text type "file_changed|endpoint_spec|schema"
        text manifest "JSON"
    }

    SHIPS_LOG {
        int id PK
        text crew_id FK
        text event_type "deployed|lost|exited"
        text detail "JSON"
    }

    STARBASE_CONFIG {
        text key PK
        text value "JSON"
    }

    SECTORS ||--o{ MISSIONS : "has"
    SECTORS ||--o{ CREW : "hosts"
    SECTORS ||--o{ CARGO : "produces"
    SECTORS ||--o{ SUPPLY_ROUTES : "upstream"
    SECTORS ||--o{ SUPPLY_ROUTES : "downstream"
    MISSIONS ||--o| CREW : "assigned to"
    MISSIONS ||--o| MISSIONS : "depends on"
    CREW ||--o{ COMMS : "sends"
    CREW ||--o{ CARGO : "produces"
    CREW ||--o{ SHIPS_LOG : "generates"
